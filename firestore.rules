rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidHistoryItem(data) {
      return data.keys().hasAll(['userId', 'productName', 'output', 'tone', 'timestamp', 'features']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.productName is string && data.productName.size() <= 200 &&
             data.output is string && data.output.size() <= 50000 &&
             data.tone is string && data.tone.size() <= 50 &&
             data.features is string && data.features.size() <= 2000 &&
             data.timestamp == request.time;
    }

    // --- Rules ---
    match /users/{userId} {
      // User path itself is private
      allow get: if isOwner(userId);
      
      match /history/{historyId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(historyId);
        
        allow create: if isOwner(userId) && 
                         isValidId(historyId) && 
                         isValidHistoryItem(incoming());
                         
        // Descriptions are generally immutable in this app, but if we allowed updates:
        allow update: if false; 
        
        allow delete: if isOwner(userId);
      }
    }
  }
}
